{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.d.ts",
    "shared/**/*.ts",
    "shared/**/*.d.ts",
    "scripts/**/*.mjs"
  ],
  "exclude": ["**/dist/**", "**/build/**", "**/node_modules/**"]
}
