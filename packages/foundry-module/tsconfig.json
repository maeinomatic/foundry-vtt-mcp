{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "types": ["@league-of-foundry-developers/foundry-vtt-types"],
    "paths": {
      "@maeinomatic/foundry-mcp-shared": ["../../shared/src/index.ts"],
      "@maeinomatic/foundry-mcp-shared/*": ["../../shared/src/*"]
    }
  },
  "include": ["src/**/*", "types/**/*"],
  "references": [{ "path": "../../shared" }],
  "exclude": ["dist", "**/*.test.*", "**/*.spec.*"]
}
