{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "paths": {
      "@maeinomatic/foundry-mcp-shared": ["../../shared/src/index.ts"],
      "@maeinomatic/foundry-mcp-shared/*": ["../../shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "references": [{ "path": "../../shared" }],
  "exclude": ["dist", "**/*.test.*", "**/*.spec.*"]
}
