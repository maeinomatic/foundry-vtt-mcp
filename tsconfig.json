{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": false,
    "checkJs": false,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "importHelpers": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@maeinomatic/foundry-mcp-shared": ["./shared/src/index.ts"],
      "@maeinomatic/foundry-mcp-shared/*": ["./shared/src/*"],
      "@shared/*": ["./shared/*"],
      "@foundry-module/*": ["./packages/foundry-module/*"],
      "@mcp-server/*": ["./packages/mcp-server/src/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["packages/**/*.ts", "packages/**/*.d.ts", "shared/**/*.ts", "shared/**/*.d.ts"],
  "exclude": ["node_modules", "**/dist", "**/build", "**/*.test.*"],
  "references": [
    {
      "path": "./packages/mcp-server"
    },
    {
      "path": "./packages/foundry-module"
    },
    {
      "path": "./shared"
    }
  ]
}
